generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AUTHENTICATION & USERS
// ==========================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  avatarUrl     String?
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  purchaseOrders PurchaseOrder[] @relation("PoCreator")
  salesOrders    SalesOrder[]    @relation("SoCreator")
  auditLogs      AuditLog[]
  stockTransfers StockTransfer[] @relation("TransferCreator")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // Super Admin, Admin, Warehouse Manager, etc.
  description String?
  
  permissions Permission[]
  users       User[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(uuid())
  resource    String   // e.g., 'INVENTORY', 'SALES_ORDERS'
  action      String   // e.g., 'CREATE', 'READ', 'UPDATE', 'DELETE'
  
  roles       Role[]

  @@unique([resource, action])
}

// ==========================================
// CORE ENTITIES
// ==========================================

model Customer {
  id              String   @id @default(uuid())
  name            String
  email           String?
  phone           String?
  company         String?
  taxId           String?
  creditLimit     Decimal? @db.Decimal(10, 2)
  outstandingBal  Decimal  @default(0) @db.Decimal(10, 2)
  notes           String?  @db.Text
  
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  
  salesOrders     SalesOrder[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Vendor {
  id              String   @id @default(uuid())
  name            String
  email           String?
  phone           String?
  company         String?
  taxId           String?
  paymentTerms    String?
  notes           String?  @db.Text
  
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  
  purchaseOrders  PurchaseOrder[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// INVENTORY & PRODUCTS
// ==========================================

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  
  products    Product[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String   @id @default(uuid())
  sku             String   @unique
  barcode         String?  @unique
  name            String
  description     String?  @db.Text
  unitPrice       Decimal  @db.Decimal(10, 2)
  costPrice       Decimal  @db.Decimal(10, 2)
  weight          Decimal? @db.Decimal(10, 2)
  unitOfMeasure   String   @default("pcs")
  reorderLevel    Int      @default(0)
  isActive        Boolean  @default(true)
  
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  
  inventory       Inventory[]
  poLines         PurchaseOrderLine[]
  soLines         SalesOrderLine[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Warehouse {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  location        String?
  isActive        Boolean  @default(true)
  
  inventory       Inventory[]
  zones           WarehouseZone[]
  transfersFrom   StockTransfer[] @relation("SourceWarehouse")
  transfersTo     StockTransfer[] @relation("DestinationWarehouse")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WarehouseZone {
  id              String   @id @default(uuid())
  name            String   // e.g., A1, Cold Storage, etc.
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  
  inventory       Inventory[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Inventory {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  
  zoneId          String?
  zone            WarehouseZone? @relation(fields: [zoneId], references: [id])
  
  quantityOnHand  Int      @default(0)
  quantityAllocated Int    @default(0)
  quantityAvailable Int    @default(0)
  
  batchNumber     String?
  expiryDate      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([productId, warehouseId, batchNumber])
}

model StockTransfer {
  id              String   @id @default(uuid())
  referenceNumber String   @unique
  status          String   // DRAFT, PENDING, IN_TRANSIT, COMPLETED, CANCELLED
  
  sourceId        String
  source          Warehouse @relation("SourceWarehouse", fields: [sourceId], references: [id])
  
  destinationId   String
  destination     Warehouse @relation("DestinationWarehouse", fields: [destinationId], references: [id])
  
  createdById     String
  createdBy       User     @relation("TransferCreator", fields: [createdById], references: [id])
  
  transferDate    DateTime?
  notes           String?
  
  lines           StockTransferLine[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StockTransferLine {
  id              String   @id @default(uuid())
  transferId      String
  transfer        StockTransfer @relation(fields: [transferId], references: [id])
  
  productId       String
  quantity        Int
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// ORDERS & BILLING
// ==========================================

model PurchaseOrder {
  id              String   @id @default(uuid())
  poNumber        String   @unique
  status          String   // DRAFT, PENDING_APPROVAL, APPROVED, PARTIAL_RECEIPT, RECEIVED, CANCELLED
  orderDate       DateTime
  expectedDate    DateTime?
  
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  
  createdById     String
  createdBy       User     @relation("PoCreator", fields: [createdById], references: [id])
  
  subtotal        Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal  @default(0) @db.Decimal(10, 2)
  
  notes           String?  @db.Text
  terms           String?  @db.Text
  
  lines           PurchaseOrderLine[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PurchaseOrderLine {
  id              String   @id @default(uuid())
  poId            String
  po              PurchaseOrder @relation(fields: [poId], references: [id])
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  quantityOrdered Int
  quantityReceived Int     @default(0)
  unitPrice       Decimal  @db.Decimal(10, 2)
  totalPrice      Decimal  @db.Decimal(10, 2)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SalesOrder {
  id              String   @id @default(uuid())
  soNumber        String   @unique
  status          String   // DRAFT, CONFIRMED, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  orderDate       DateTime
  deliveryDate    DateTime?
  
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  
  createdById     String
  createdBy       User     @relation("SoCreator", fields: [createdById], references: [id])
  
  subtotal        Decimal  @default(0) @db.Decimal(10, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal  @default(0) @db.Decimal(10, 2)
  
  shippingAddress String?  @db.Text
  billingAddress  String?  @db.Text
  notes           String?  @db.Text
  
  lines           SalesOrderLine[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SalesOrderLine {
  id              String   @id @default(uuid())
  soId            String
  so              SalesOrder @relation(fields: [soId], references: [id])
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  quantityOrdered Int
  quantityShipped Int      @default(0)
  unitPrice       Decimal  @db.Decimal(10, 2)
  discount        Decimal  @default(0) @db.Decimal(10, 2)
  totalPrice      Decimal  @db.Decimal(10, 2)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// SYSTEM LOGS
// ==========================================

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  action      String   // CREATE, UPDATE, DELETE, LOGIN
  entity      String   // e.g., Product, Order
  entityId    String
  details     Json?    // Stores what changed
  
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
}

model Notification {
  id          String   @id @default(uuid())
  userId      String   // Recipient
  title       String
  message     String
  type        String   // INFO, WARNING, SUCCESS, ERROR
  isRead      Boolean  @default(false)
  link        String?  // Optional link to related entity
  
  createdAt   DateTime @default(now())
}
